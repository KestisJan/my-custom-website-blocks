{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "create-block/feature-item",
  "version": "0.1.0",
  "title": "Feature Item",
  "category": "design",
  "attributes": {
    "title": {
      "type": "string",
      "source": "html",
      "selector": "h3"
    },
    "description": {
      "type": "string",
      "source": "html",
      "selector": "p"
    },
    "mediaId": {
      "type": "number"
    },
    "mediaUrl": {
      "type": "string",
      "default": ""
    },
    "buttonText": {
      "type": "string",
      "default": "Learn More"
    },
    "buttonUrl": {
      "type": "string",
      "default": ""
    },
    "backgroundColor": {
      "type": "string",
      "default": "#ffffff"
    }
  },
  "parent": [
    "create-block/feature-grid"
  ],
  "editorScript": "file:../../index.js",
  "style": "file:../../style-index.css",
  "editorStyle": "file:../../index.css"
}