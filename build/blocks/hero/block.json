{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "my-custom-site/hero",
  "title": "Hero Section",
  "category": "layout",
  "attributes": {
    "title": {
      "type": "string",
      "default": "Building the Future"
    },
    "subText": {
      "type": "string",
      "default": "Your subtitle goes here."
    },
    "bgImageUrl": {
      "type": "string"
    },
    "overlayOpacity": {
      "type": "number",
      "default": 40
    }
  },
  "supports": {
    "align": [
      "full",
      "wide"
    ],
    "html": false
  },
  "editorScript": "file:../../index.js",
  "editorStyle": "file:../../index.css",
  "style": "file:./style.css"
}